# === Smart Learn Environment Variables ===
# Copy this file to .env and fill in your values
#   cp .env.example .env

# --- Database ---
DB_PASSWORD=change-me-to-a-strong-password

# --- JWT ---
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# --- Storage Provider ---
# Options: local | s3 | azure | aliyun
STORAGE_PROVIDER=local

# --- AWS S3 (only needed if STORAGE_PROVIDER=s3) ---
# S3_BUCKET=smartlearn-materials
# S3_REGION=ap-southeast-1
# S3_ENDPOINT=       # leave empty for real S3, set for MinIO

# --- Port ---
HTTP_PORT=80

# --- Node Environment ---
NODE_ENV=production
